# ---------------------------------------------------------------------------
# LinAgent — 最小配置
# 只需两行就能跑：一个 provider 名 + 一个 key。
# ---------------------------------------------------------------------------

LLM_PROVIDER=openai
LLM_API_KEY=sk-...

# ---------------------------------------------------------------------------
# 可用的 provider 预设（自动带上 base_url、协议、默认模型）：
#
#   openai       OpenAI 官方                     → gpt-4o-mini
#   anthropic    Anthropic Claude                → claude-haiku-4-5-20251001
#   deepseek     DeepSeek                        → deepseek-chat
#   moonshot     Moonshot / Kimi                 → moonshot-v1-8k
#   dashscope    阿里 DashScope / 千问           → qwen-plus
#   zhipu        智谱 GLM                        → glm-4-flash
#   openrouter   OpenRouter 聚合器               → openai/gpt-4o-mini
#   groq         Groq                            → llama-3.1-8b-instant
#   ollama       本地 Ollama（OpenAI 兼容端点）  → llama3.1（无需 key）
#
# 常见做法（挑一个即可）：
#   LLM_PROVIDER=deepseek     LLM_API_KEY=sk-xxxxx
#   LLM_PROVIDER=moonshot     LLM_API_KEY=sk-xxxxx
#   LLM_PROVIDER=dashscope    LLM_API_KEY=sk-xxxxx
#   LLM_PROVIDER=anthropic    LLM_API_KEY=sk-ant-xxxxx
#   LLM_PROVIDER=ollama                              # 本地 ollama 不用 key
#
# key 也可以放到 provider 的惯用变量里，LinAgent 会自动读取：
#   OPENAI_API_KEY / ANTHROPIC_API_KEY / DEEPSEEK_API_KEY /
#   MOONSHOT_API_KEY / DASHSCOPE_API_KEY / ZHIPU_API_KEY /
#   OPENROUTER_API_KEY / GROQ_API_KEY
# ---------------------------------------------------------------------------

# 可选覆盖：
# LLM_MODEL=gpt-4o                      # 覆盖 preset 的默认模型
# LLM_BASE_URL=https://your-proxy/v1    # 覆盖 preset 的 baseUrl（如公司代理）
# LLM_TIMEOUT_MS=60000

# --- Agent runtime ---
AGENT_MAX_TURNS=8
AGENT_CONTEXT_MAX_MESSAGES=24
